# Copy this file to `.env` (in the studio folder) and fill in your values.
# You can find these in your Sanity project at https://www.sanity.io/manage

SANITY_STUDIO_PROJECT_ID=replace-with-your-project-id
SANITY_STUDIO_DATASET=production

# A write token. Only needed for the one-time seed script.
# Create at: https://www.sanity.io/manage -> your project -> API -> Tokens
# Permissions: "Editor" or "Deploy Studio" works fine.
SANITY_AUTH_TOKEN=replace-with-your-write-token
