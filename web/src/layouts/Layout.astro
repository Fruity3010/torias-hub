---
import Header from '~/components/Header.astro'
import Footer from '~/components/Footer.astro'

interface Props {
  title?: string
  description?: string
  active?: 'home' | 'about' | 'services' | 'programs' | 'stories' | 'contact'
  site?: any
  image?: string
}
const {
  title = 'TE Limited | Media, Training & Community Impact',
  description = 'TE Limited delivers media, communication, training, event hosting, and community impact services for brands, organizations, and communities.',
  active = 'home',
  site,
  image = '/assets/gallery/speaking-event.jpg',
} = Astro.props

const siteUrl = 'https://teltd.com.ng'
const pathname = Astro.url.pathname === '/' ? '/' : Astro.url.pathname.replace(/\/$/, '')
const canonicalUrl = new URL(pathname, siteUrl).toString()
const imageUrl = image.startsWith('http') ? image : new URL(image, siteUrl).toString()
const normalizeSeoText = (value: string) =>
  value
    .replace(/Toria['’]s Hub Youth Foundation/g, 'TE Limited')
    .replace(/Toria['’]s Hub/g, 'TE Limited')
    .replace(/toriashub\.org/g, 'teltd.com.ng')
const normalizedTitle = normalizeSeoText(title)
const normalizedDescription = normalizeSeoText(description)
const organizationJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TE Limited',
  url: siteUrl,
  logo: new URL('/assets/gallery/speaking-event.jpg', siteUrl).toString(),
  email: site?.email || 'info@teltd.com.ng',
  telephone: site?.phone,
  address: site?.address
    ? {
        '@type': 'PostalAddress',
        addressLocality: site.address,
        addressCountry: 'NG',
      }
    : undefined,
  sameAs: (site?.socialLinks || []).map((link: any) => link.url).filter(Boolean),
}
const websiteJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'TE Limited',
  url: siteUrl,
}
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={normalizedDescription} />
  <title>{normalizedTitle}</title>
  <link rel="canonical" href={canonicalUrl} />
  <meta name="robots" content="index, follow" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="TE Limited" />
  <meta property="og:title" content={normalizedTitle} />
  <meta property="og:description" content={normalizedDescription} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={imageUrl} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={normalizedTitle} />
  <meta name="twitter:description" content={normalizedDescription} />
  <meta name="twitter:image" content={imageUrl} />
  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
  <link rel="stylesheet" href="/css/styles.css" />
  <script type="application/ld+json" set:html={JSON.stringify(organizationJsonLd)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(websiteJsonLd)}></script>
</head>
<body>
  <Header active={active} site={site} />
  <slot />
  <Footer site={site} />
  <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" is:inline></script>
  <script src="/js/main.js" is:inline></script>
</body>
</html>
