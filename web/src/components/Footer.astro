---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">{brandName}<span>{brandSuffix}</span></div>
        <p>{footerTagline}</p>
        <div class="footer-socials">
          {socials.map((s: any) => (
            <a href={s.url} target="_blank" rel="noopener" class="footer-social-link" aria-label={s.network}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d={socialPaths[s.network] || ''}/></svg>
            </a>
          ))}
        </div>
      </div>

      {columns.map((col: any) => (
        <div class="footer-col">
          <h4>{col.heading}</h4>
          <ul>
            {(col.links || []).map((l: any) => (
              <li><a href={l.href}>{l.label}</a></li>
            ))}
          </ul>
        </div>
      ))}

      <div class="footer-col">
        <h4>Contact</h4>
        <ul>
          {data.address && <li class="footer-contact-item"><strong>Address</strong>{data.address}</li>}
          {email && <li class="footer-contact-item"><strong>Email</strong><a href={`mailto:${email}`}>{email}</a></li>}
          {data.phone && <li class="footer-contact-item"><strong>Phone</strong>{data.phone}</li>}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>{copyright}</p>
      <p>{footerSubline}</p>
    </div>
  </div>
</footer>
