---
import {site as siteDefaults} from '~/lib/defaults'

interface Props {
  site?: any
}
const {site} = Astro.props
const data = {...siteDefaults, ...(site || {})}
const columns = data.footerColumns?.length ? data.footerColumns : siteDefaults.footerColumns
const socials = data.socialLinks?.length ? data.socialLinks : siteDefaults.socialLinks
const rawBrand = `${data.brandName || ''}${data.brandSuffix || ''}`
const brandName = /toria/i.test(rawBrand) ? 'TE ' : data.brandName
const brandSuffix = /toria/i.test(rawBrand) ? 'Limited' : data.brandSuffix
const footerTagline = /toria/i.test(data.footerTagline || '') ? siteDefaults.footerTagline : data.footerTagline
const copyright = /toria/i.test(data.copyright || '') ? siteDefaults.copyright : data.copyright
const footerSubline = /african youth|digital and ai/i.test(data.footerSubline || '') ? siteDefaults.footerSubline : data.footerSubline
const email = /toriashub/i.test(data.email || '') ? siteDefaults.email : data.email

const socialPaths: Record<string, string> = {
